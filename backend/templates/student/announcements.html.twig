{% extends 'student/base.html.twig' %}

{% block title %}Announcements{% endblock %}

{% block body %}
    <header class="dashboard-header">
        <div>
            <h1>Announcements</h1>
            <div style="display:flex;align-items:center;gap:12px;margin-top:6px;">
                <p class="date-display" style="margin:0;">Notices and updates from your supervisor</p>
                <span class="unread-badge" id="unread-badge" style="display:none;"></span>
            </div>
        </div>
        <div class="admin-profile">
            <div class="avatar stu-avatar"></div>
            <span>Room {{ app.user.student.room ? app.user.student.room.roomNumber : 'N/A' }}</span>
        </div>
    </header>

    <!-- Filter Bar -->
    <div class="filter-bar">
        <input type="text" class="search-input" id="ann-search" placeholder="🔍  Search announcements…" oninput="filterAnn()">
        <span class="filter-label">Category:</span>
        <select class="filter-select" id="ann-cat" onchange="filterAnn()">
            <option value="">All Categories</option>
            <option value="general">General</option>
            <option value="maintenance">Maintenance</option>
            <option value="rules">Rules</option>
            <option value="event">Event</option>
            <option value="urgent">Urgent</option>
        </select>
        <span class="student-count-label" id="ann-visible-count">Showing {{ announcements|length }} announcements</span>
    </div>

    <!-- Announcements Grid -->
    <div class="dashboard-grid" style="grid-template-columns:1fr;" id="ann-grid">

        {% for announcement in announcements %}
        <div class="announcement-card unread" data-id="ann-{{ announcement.id }}" data-cat="{{ announcement.category|lower }}" data-text="{{ announcement.title|lower }} {{ announcement.body|lower }}" onclick="markRead(this)">
            <div class="announcement-card-header">
                <span class="ann-category-badge {{ announcement.category|lower }}">{{ announcement.category }}</span>
                <span class="ann-date">{{ announcement.createdAt|date('M d, Y') }}</span>
            </div>
            <h4 class="ann-card-title">{{ announcement.title }}</h4>
            <p class="ann-card-body">{{ announcement.body }}</p>
        </div>
        {% endfor %}

    </div>

    <p id="ann-empty" style="display:none;text-align:center;padding:40px;color:#64748b;">🔍 No announcements match your search or filter.</p>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // ── All announcement IDs ──
        const ALL_ANN_IDS = [{% for ann in announcements %}'ann-{{ ann.id }}'{{ not loop.last ? ',' : '' }}{% endfor %}];
        const STORAGE_KEY = 'hms_read_ann';

        // ── Load read state from localStorage ──
        function getReadIds() {
            return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
        }
        function setReadIds(ids) {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(ids));
        }

        // ── Initialize page: restore read state, update badges ──
        function initUnread() {
            const readIds = getReadIds();
            const cards   = document.querySelectorAll('#ann-grid .announcement-card');

            cards.forEach(card => {
                if (readIds.includes(card.dataset.id)) {
                    card.classList.remove('unread');
                }
            });

            updateUnreadUI();
        }

        function updateUnreadUI() {
            const unreadCount = document.querySelectorAll('#ann-grid .announcement-card.unread').length;
            const badge = document.getElementById('unread-badge');
            const dot   = document.getElementById('ann-notif-dot');

            if (unreadCount > 0) {
                badge.style.display = 'inline-flex';
                badge.textContent   = unreadCount + ' Unread';
                dot.style.display   = 'inline-flex';
                dot.textContent     = unreadCount;
            } else {
                badge.style.display = 'none';
                dot.style.display   = 'none';
            }
        }

        // ── Mark a card as read when clicked ──
        function markRead(card) {
            if (!card.classList.contains('unread')) return;
            card.classList.remove('unread');

            const readIds = getReadIds();
            if (!readIds.includes(card.dataset.id)) {
                readIds.push(card.dataset.id);
                setReadIds(readIds);
            }
            updateUnreadUI();
        }

        // ── Filter ──
        function filterAnn() {
            const query = document.getElementById('ann-search').value.toLowerCase();
            const cat   = document.getElementById('ann-cat').value;
            const cards = document.querySelectorAll('#ann-grid .announcement-card');
            let visible = 0;
            cards.forEach(c => {
                const matchQ = !query || c.dataset.text.includes(query) || c.querySelector('.ann-card-title').textContent.toLowerCase().includes(query);
                const matchC = !cat   || c.dataset.cat === cat;
                c.style.display = (matchQ && matchC) ? '' : 'none';
                if (matchQ && matchC) visible++;
            });
            document.getElementById('ann-empty').style.display = visible === 0 ? 'block' : 'none';
            document.getElementById('ann-visible-count').textContent = `Showing ${visible} announcement${visible !== 1 ? 's' : ''}`;
        }

        // Init on page load
        initUnread();
    </script>
{% endblock %}
