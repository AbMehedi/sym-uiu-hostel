<!-- ── Assign Task Modal ── -->
<div class="modal-overlay" id="task-modal-overlay" onclick="closeTaskModal(event)">
    <div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="task-modal-title">
        <div class="modal-header">
            <h3 id="task-modal-title">Assign Task</h3>
            <button class="modal-close-btn" onclick="closeTaskModal()" aria-label="Close">×</button>
        </div>
        <div class="modal-body">
            <form id="task-form" method="POST" action="{{ path('admin_tasks_new') }}">
                <input type="hidden" id="task-supervisor-id" name="supervisorId" value="">
                <div class="form-group">
                    <label>Supervisor</label>
                    <p id="task-supervisor-name" style="color:white;font-weight:600;padding:8px 0;"></p>
                </div>
                <div class="form-group">
                    <label for="task-desc">Task Title <span style="color:#ef4444;">*</span></label>
                    <input type="text" id="task-desc" name="title" class="form-control announce-input" placeholder="e.g. Inspect Block A bathrooms" required maxlength="150">
                </div>
                <div class="form-group">
                    <label for="task-description">Description (optional)</label>
                    <textarea id="task-description" name="description" class="form-control announce-input" rows="3" placeholder="Additional details…"></textarea>
                </div>
                <div class="modal-detail-grid">
                    <div class="form-group">
                        <label for="task-due">Due Date <span style="color:#ef4444;">*</span></label>
                        <input type="date" id="task-due" name="dueDate" class="form-control announce-input" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline" onclick="closeTaskModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary">Assign Task</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ── Assign Student Modal ── -->
