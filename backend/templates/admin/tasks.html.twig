{% extends 'admin/base.html.twig' %}

{% block title %}Task Management — Admin{% endblock %}

{% block body %}
<header class="dashboard-header">
    <div>
        <h1>Task Management</h1>
        <p style="color:#94a3b8;">Assign and track supervisor tasks</p>
    </div>
</header>

{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div style="margin-bottom:16px;padding:12px 20px;border-radius:8px;color:#fff;background:{% if type=='success' %}#064e3b{% else %}#7f1d1d{% endif %};">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

<!-- Assign New Task Form -->
<div class="dashboard-box" style="margin-bottom:28px;">
    <div class="box-header"><h3>Assign New Task</h3></div>
    <form method="post" action="{{ path('admin_tasks_new') }}" style="padding:20px;display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div>
            <label style="display:block;margin-bottom:6px;color:#94a3b8;font-size:.85rem;">Supervisor *</label>
            <select name="supervisorId" required style="width:100%;padding:10px 14px;background:#1e293b;border:1px solid #334155;border-radius:8px;color:#e2e8f0;">
                <option value="">Select Supervisor</option>
                {% for sup in supervisors %}
                    <option value="{{ sup.id }}">{{ sup.user.name }} — {{ sup.blockAssigned }}</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label style="display:block;margin-bottom:6px;color:#94a3b8;font-size:.85rem;">Task Title *</label>
            <input type="text" name="title" required placeholder="e.g. Monthly Room Inspection"
                   style="width:100%;padding:10px 14px;background:#1e293b;border:1px solid #334155;border-radius:8px;color:#e2e8f0;">
        </div>
        <div>
            <label style="display:block;margin-bottom:6px;color:#94a3b8;font-size:.85rem;">Due Date</label>
            <input type="date" name="dueDate"
                   style="width:100%;padding:10px 14px;background:#1e293b;border:1px solid #334155;border-radius:8px;color:#e2e8f0;">
        </div>
        <div>
            <label style="display:block;margin-bottom:6px;color:#94a3b8;font-size:.85rem;">Description</label>
            <input type="text" name="description" placeholder="Optional details"
                   style="width:100%;padding:10px 14px;background:#1e293b;border:1px solid #334155;border-radius:8px;color:#e2e8f0;">
        </div>
        <div style="grid-column:1/-1;text-align:right;">
            <button type="submit" class="btn btn-primary">Assign Task</button>
        </div>
    </form>
</div>

<!-- Task List grouped by status -->
{% set statuses = {
    'pending': { 'label': 'Pending', 'css': 'pending' },
    'in_progress': { 'label': 'In Progress', 'css': 'in-progress' },
    'done': { 'label': 'Done', 'css': 'done' }
} %}
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;">

    {% for value, config in statuses %}
    <div class="dashboard-box">
        <div class="box-header">
            <h3><span class="status {{ config.css }}">{{ config.label }}</span></h3>
        </div>
        <div style="padding:12px;">
            {% set found = false %}
            {% for task in tasks %}
                {% if task.status.value == value %}
                    {% set found = true %}
                    <div style="background:#1e293b;border:1px solid #334155;border-radius:10px;padding:14px 16px;margin-bottom:10px;">
                        <div style="font-weight:600;color:#e2e8f0;margin-bottom:4px;">{{ task.title }}</div>
                        <div style="font-size:.82rem;color:#64748b;margin-bottom:6px;">
                            👤 {{ task.supervisor.user.name }} &nbsp;|&nbsp; {{ task.supervisor.blockAssigned }}
                        </div>
                        {% if task.description %}
                            <div style="font-size:.84rem;color:#94a3b8;margin-bottom:6px;">{{ task.description }}</div>
                        {% endif %}
                        {% if task.dueDate %}
                            <div style="font-size:.8rem;color:{% if task.dueDate < date() %}#ef4444{% else %}#f59e0b{% endif %};">
                                Due: {{ task.dueDate|date('D, d M Y') }}
                            </div>
                        {% endif %}
                        <form method="post" action="{{ path('admin_tasks_delete', {id: task.id}) }}"
                              style="margin-top:10px;"
                              onsubmit="return confirm('Remove task: {{ task.title|escape('js') }}?')">
                            <button type="submit" style="font-size:.78rem;background:none;border:1px solid #ef4444;color:#ef4444;padding:4px 10px;border-radius:6px;cursor:pointer;">
                                Remove
                            </button>
                        </form>
                    </div>
                {% endif %}
            {% endfor %}
            {% if not found %}
                <p style="color:#475569;font-size:.88rem;text-align:center;padding:20px 0;">No {{ config.label|lower }} tasks</p>
            {% endif %}
        </div>
    </div>
    {% endfor %}

</div>
{% endblock %}
