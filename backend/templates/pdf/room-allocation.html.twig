<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Room Allocation Report</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 12px; color: #1e293b; padding: 30px; }
        .header { text-align: center; margin-bottom: 24px; border-bottom: 3px solid #2563eb; padding-bottom: 16px; }
        .header h1 { font-size: 22px; color: #1e3a8a; font-weight: bold; margin-bottom: 4px; }
        .header p { font-size: 11px; color: #64748b; }
        .meta-row { display: flex; justify-content: space-between; margin-bottom: 20px; font-size: 11px; color: #64748b; }
        .summary-box { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 6px; padding: 12px 16px; margin-bottom: 20px; display: flex; gap: 40px; }
        .summary-item { }
        .summary-item .label { font-size: 10px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; }
        .summary-item .value { font-size: 18px; font-weight: bold; color: #1e40af; }
        .block-section { margin-bottom: 24px; }
        .block-title { background: #1e40af; color: white; padding: 8px 12px; font-size: 13px; font-weight: bold; border-radius: 4px 4px 0 0; }
        table { width: 100%; border-collapse: collapse; }
        thead { background: #dbeafe; }
        th { padding: 8px 10px; text-align: left; font-size: 11px; color: #1e3a8a; text-transform: uppercase; letter-spacing: 0.3px; border-bottom: 1px solid #93c5fd; }
        td { padding: 7px 10px; border-bottom: 1px solid #e2e8f0; font-size: 11px; }
        tr:nth-child(even) { background: #f8fafc; }
        .status-badge { background: #dcfce7; color: #166534; padding: 2px 8px; border-radius: 10px; font-size: 10px; font-weight: bold; }
        .footer { margin-top: 30px; text-align: center; font-size: 10px; color: #94a3b8; border-top: 1px solid #e2e8f0; padding-top: 12px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>🏠 UIU Hostel Management System</h1>
        <p>Official Room Allocation Report — Generated by System</p>
    </div>

    <div class="meta-row">
        <span><strong>Report Date:</strong> {{ generatedAt|date('d M Y, H:i') }}</span>
        <span><strong>Document Type:</strong> Room Allocation Register</span>
    </div>

    <div class="summary-box">
        <div class="summary-item">
            <div class="label">Total Rooms</div>
            <div class="value">{{ totalRooms }}</div>
        </div>
        <div class="summary-item">
            <div class="label">Active Residents</div>
            <div class="value">{{ activeCount }}</div>
        </div>
        <div class="summary-item">
            <div class="label">Blocks</div>
            <div class="value">{{ grouped|keys|length }}</div>
        </div>
    </div>

    {% for block, rooms in grouped %}
    <div class="block-section">
        <div class="block-title">Block: {{ block }}</div>
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Room No.</th>
                    <th>Student Name</th>
                    <th>Student ID</th>
                    <th>Contact</th>
                    <th>Assigned Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                {% set rownum = 1 %}
                {% for roomNo, assignments in rooms %}
                    {% for a in assignments %}
                    <tr>
                        <td>{{ rownum }}</td>
                        <td><strong>{{ roomNo }}</strong></td>
                        <td>{{ a.student.user.name }}</td>
                        <td>{{ a.student.studentNumber }}</td>
                        <td>{{ a.student.phone ?? '—' }}</td>
                        <td>{{ a.assignedDate|date('d M Y') }}</td>
                        <td><span class="status-badge">Active</span></td>
                    </tr>
                    {% set rownum = rownum + 1 %}
                    {% endfor %}
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <p style="text-align:center;color:#94a3b8;padding:40px 0;">No active room assignments found.</p>
    {% endfor %}

    <div class="footer">
        UIU Hostel Management System &bull; Confidential &bull; Generated on {{ generatedAt|date('d M Y') }}
    </div>
</body>
</html>
